{
  "name": "add_card_happy",
  "description": "Appending a card to an existing column increments length and preserves other columns.",
  "board_before": {
    "version": 1,
    "name": "Demo",
    "columns": [
      {
        "name": "Todo",
        "cards": [
          { "title": "existing" }
        ]
      },
      {
        "name": "Done",
        "cards": []
      }
    ]
  },
  "op": {
    "type": "add_card",
    "column": "Todo",
