    "version": 1,
    "name": "Demo",
    "columns": [
      {
        "name": "Todo",
        "cards": [
          { "title": "existing" },
          { "title": "added" }
        ]
      },
      {
        "name": "Done",
        "cards": []
      }
    ]
  }
