{
  "name": "rename_column_happy",
  "description": "rename_column replaces column name in place.",
  "board_before": {
    "version": 1,
    "columns": [
      { "name": "Todo", "cards": [{ "title": "a" }] },
      { "name": "Done", "cards": [] }
