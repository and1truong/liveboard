#!/usr/bin/env bash
# Pre-commit hook: auto-format staged Go files with gofmt.

staged_go_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$')

if [ -z "$staged_go_files" ]; then
    exit 0
fi

# Format and re-stage
for file in $staged_go_files; do
    if [ -f "$file" ]; then
        gofmt -w "$file"
        git add "$file"
    fi
done

# nilaway: block commit if nil-safety check fails (skip if not installed)
# Skip with: SKIP_NILAWAY=1 git commit ...
if [[ "${SKIP_NILAWAY:-}" == "1" ]]; then
    echo "Skipping nilaway (SKIP_NILAWAY=1)."
elif command -v nilaway &> /dev/null; then
    echo "Running nilaway..."
    if ! nilaway ./...; then
        echo "nilaway found issues. Commit blocked."
        exit 1
    fi
fi
